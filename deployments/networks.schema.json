{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://proof-bounty.invalid/schemas/evm-networks-v1.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["$schema", "schemaVersion", "compiler", "evmVersion", "networks"],
  "properties": {
    "$schema": { "const": "./networks.schema.json" },
    "schemaVersion": { "const": 1 },
    "compiler": { "const": "0.8.36" },
    "evmVersion": { "const": "paris" },
    "networks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["key", "name", "chainId", "environment", "rpcEnvironmentVariable", "variants"],
        "properties": {
          "key": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "name": { "type": "string", "minLength": 1 },
          "chainId": { "type": "integer", "minimum": 1 },
          "environment": { "enum": ["mainnet", "testnet"] },
          "rpcEnvironmentVariable": { "type": "string", "pattern": "^[A-Z][A-Z0-9_]+$" },
          "variants": {
            "type": "array",
            "minItems": 2,
            "maxItems": 2,
            "uniqueItems": true,
            "items": { "enum": ["native", "erc20"] }
          }
        }
      }
    }
  }
}
