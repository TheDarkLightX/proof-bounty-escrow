{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://proof-bounty.invalid/schemas/claim-package-v1.json",
  "title": "Proof bounty claim package V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "chainId",
    "escrow",
    "deploymentId",
    "claim",
    "economics",
    "commitment",
    "attestationDigest",
    "result",
    "signatures"
  ],
  "properties": {
    "schema": { "const": "proof-bounty-claim-package/v1" },
    "chainId": { "type": "integer", "minimum": 1 },
    "escrow": { "$ref": "#/$defs/address" },
    "deploymentId": { "$ref": "#/$defs/hash" },
    "claim": {
      "type": "object",
      "additionalProperties": false,
      "required": ["bountyId", "solver", "resultDigest", "salt"],
      "properties": {
        "bountyId": { "$ref": "#/$defs/uint" },
        "solver": { "$ref": "#/$defs/address" },
        "resultDigest": { "$ref": "#/$defs/hash" },
        "salt": { "$ref": "#/$defs/hash" }
      }
    },
    "economics": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reward", "verifierFee", "fundedAmount"],
      "properties": {
        "reward": { "$ref": "#/$defs/uint" },
        "verifierFee": { "$ref": "#/$defs/uint" },
        "fundedAmount": { "$ref": "#/$defs/uint" }
      }
    },
    "commitment": { "$ref": "#/$defs/hash" },
    "attestationDigest": { "$ref": "#/$defs/hash" },
    "result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["keccak256", "mediaType", "uris"],
      "properties": {
        "keccak256": { "$ref": "#/$defs/hash" },
        "mediaType": { "type": "string", "minLength": 1, "maxLength": 100 },
        "uris": {
          "type": "array",
          "minItems": 1,
          "maxItems": 8,
          "uniqueItems": true,
          "items": { "type": "string", "pattern": "^(ipfs://|https://|ar://).+" }
        }
      }
    },
    "signatures": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["verifierIndex", "signature"],
        "properties": {
          "verifierIndex": { "type": "integer", "minimum": 0, "maximum": 2 },
          "signature": { "type": "string", "pattern": "^0x[0-9a-fA-F]{130}$" }
        }
      }
    }
  },
  "$defs": {
    "address": { "type": "string", "pattern": "^0x[0-9a-fA-F]{40}$" },
    "hash": { "type": "string", "pattern": "^0x[0-9a-fA-F]{64}$" },
    "uint": { "type": "string", "pattern": "^(0|[1-9][0-9]*)$" }
  }
}
