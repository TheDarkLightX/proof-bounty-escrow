{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://proof-bounty.invalid/schemas/job-listing-v1.json",
  "title": "Proof bounty job listing V1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "chainId", "escrow", "bountyId", "onchain", "content", "display"],
  "properties": {
    "schema": { "const": "proof-bounty-job-listing/v1" },
    "chainId": { "type": "integer", "minimum": 1 },
    "escrow": { "$ref": "#/$defs/address" },
    "bountyId": { "$ref": "#/$defs/uint" },
    "onchain": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sponsor",
        "refundRecipient",
        "asset",
        "reward",
        "verifierFee",
        "fundedAmount",
        "commitDeadline",
        "claimDeadline",
        "profileId",
        "specificationHash",
        "termsHash"
      ],
      "properties": {
        "sponsor": { "$ref": "#/$defs/address" },
        "refundRecipient": { "$ref": "#/$defs/address" },
        "asset": { "$ref": "#/$defs/address" },
        "reward": { "$ref": "#/$defs/uint" },
        "verifierFee": { "$ref": "#/$defs/uint" },
        "fundedAmount": { "$ref": "#/$defs/uint" },
        "commitDeadline": { "type": "integer", "minimum": 1 },
        "claimDeadline": { "type": "integer", "minimum": 1 },
        "profileId": { "$ref": "#/$defs/hash" },
        "specificationHash": { "$ref": "#/$defs/hash" },
        "termsHash": { "$ref": "#/$defs/hash" }
      }
    },
    "content": {
      "type": "object",
      "additionalProperties": false,
      "required": ["profile", "specification", "terms"],
      "properties": {
        "profile": { "$ref": "#/$defs/artifact" },
        "specification": { "$ref": "#/$defs/artifact" },
        "terms": { "$ref": "#/$defs/artifact" }
      }
    },
    "display": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "summary", "tags"],
      "properties": {
        "title": { "type": "string", "minLength": 1, "maxLength": 120 },
        "summary": { "type": "string", "minLength": 1, "maxLength": 2000 },
        "tags": {
          "type": "array",
          "maxItems": 12,
          "uniqueItems": true,
          "items": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]{0,31}$" }
        }
      }
    }
  },
  "$defs": {
    "address": { "type": "string", "pattern": "^0x[0-9a-fA-F]{40}$" },
    "hash": { "type": "string", "pattern": "^0x[0-9a-fA-F]{64}$" },
    "uint": { "type": "string", "pattern": "^(0|[1-9][0-9]*)$" },
    "uri": { "type": "string", "pattern": "^(ipfs://|https://|ar://).+" },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["keccak256", "mediaType", "uris"],
      "properties": {
        "keccak256": { "$ref": "#/$defs/hash" },
        "mediaType": { "type": "string", "minLength": 1, "maxLength": 100 },
        "uris": {
          "type": "array",
          "minItems": 1,
          "maxItems": 8,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/uri" }
        }
      }
    }
  }
}
