{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://proof-bounty.invalid/schemas/evaluator-profile-v1.json",
  "title": "Proof bounty evaluator profile V1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "name", "version", "evaluator", "inputs", "result", "policy"],
  "properties": {
    "schema": { "const": "proof-bounty-evaluator-profile/v1" },
    "name": { "type": "string", "minLength": 1, "maxLength": 80 },
    "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "evaluator": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sourceDigest", "runtime", "artifactDigest", "entrypoint", "network"],
      "properties": {
        "sourceDigest": { "$ref": "#/$defs/hash" },
        "runtime": { "type": "string", "minLength": 1, "maxLength": 120 },
        "artifactDigest": { "type": "string", "minLength": 1, "maxLength": 200 },
        "entrypoint": {
          "type": "array",
          "minItems": 1,
          "maxItems": 32,
          "items": { "type": "string", "maxLength": 256 }
        },
        "network": { "const": "disabled" }
      }
    },
    "inputs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["specificationMediaType", "maximumBytes"],
      "properties": {
        "specificationMediaType": { "type": "string", "minLength": 1, "maxLength": 100 },
        "maximumBytes": { "type": "integer", "minimum": 1 }
      }
    },
    "result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mediaType", "maximumBytes", "digest"],
      "properties": {
        "mediaType": { "type": "string", "minLength": 1, "maxLength": 100 },
        "maximumBytes": { "type": "integer", "minimum": 1 },
        "digest": { "const": "keccak256-raw-bytes" }
      }
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "deterministic",
        "successExitCodes",
        "timeoutSeconds",
        "memoryBytes",
        "independentRuns",
        "recommendedVerifierFeeBps",
        "estimatedVerifierSeconds"
      ],
      "properties": {
        "deterministic": { "const": true },
        "successExitCodes": {
          "type": "array",
          "minItems": 1,
          "maxItems": 16,
          "uniqueItems": true,
          "items": { "type": "integer", "minimum": 0, "maximum": 255 }
        },
        "timeoutSeconds": { "type": "integer", "minimum": 1 },
        "memoryBytes": { "type": "integer", "minimum": 1 },
        "independentRuns": { "type": "integer", "minimum": 1 },
        "recommendedVerifierFeeBps": {
          "description": "Profile recommendation only; the sponsor supplies an absolute verifier pool from max(2 smallest units, floor(50 bps of reward)) through 10000 bps of reward.",
          "type": "integer",
          "minimum": 50,
          "maximum": 10000
        },
        "estimatedVerifierSeconds": {
          "description": "Expected wall-clock work per independent verifier under the frozen resource profile.",
          "type": "integer",
          "minimum": 1
        }
      }
    }
  },
  "$defs": {
    "hash": { "type": "string", "pattern": "^0x[0-9a-fA-F]{64}$" }
  }
}
